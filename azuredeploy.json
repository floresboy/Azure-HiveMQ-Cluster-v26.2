{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "adminUsername": {
      "type": "string",
      "metadata": { "description": "Admin username for the Virtual Machines" }
    },
    "authenticationType": {
      "type": "string",
      "defaultValue": "password",
      "allowedValues": [ "password", "sshPublicKey" ],
      "metadata": { "description": "Type of authentication" }
    },
    "adminPasswordOrSSHKey": {
      "type": "securestring",
      "metadata": { "description": "Password or SSH key" }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_F4s_v2"
    },
    "hivemqVersion": {
      "type": "string",
      "defaultValue": "4.50.0"
    },
    "azureDiscoveryExtensionVersion": {
      "type": "string",
      "defaultValue": "1.3.2"
    },
    "numberOfInstances": {
      "type": "int",
      "defaultValue": 2
    },
    "deployPublicIPs": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Individual Public IPs for each VM node?" }
    },
    "deployBastion": {
      "type": "bool",
      "defaultValue": true,
      "metadata": { "description": "Deploy Azure Bastion for secure management access?" }
    }
  },
  "variables": {
    "imagePublisher": "Canonical",
    "imageOffer": "0001-com-ubuntu-server-jammy",
    "ubuntuOSVersion": "22_04-lts-gen2",
    "loadBalancersName": "hivemq-lb",
    "vmName": "hivemq-node",
    "asName": "hivemq-as",
    "nicName": "hivemq-node-nic",
    "addressPrefix": "10.0.0.0/16",
    "subnetName": "hivemq-cluster-subnet",
    "subnetPrefix": "10.0.0.0/24",
    "bastionSubnetName": "AzureBastionSubnet",
    "bastionSubnetPrefix": "10.0.1.0/26",
    "bastionHostName": "hivemq-bastion",
    "virtualNetworkName": "hivemq-cluster-vnet",
    "backendPoolName": "hivemq-node",
    "frontendName": "LoadBalancerFrontEnd",
    "healthProbeHivemq": "hivemq-node-health",
    "healthProbeControlCenter": "hivemq-control-center-health",
    "loadBalancerPublicIpName": "[concat(variables('loadBalancersName'), 'public-ip')]",
    "bastionPublicIpName": "[concat(variables('bastionHostName'), '-pip')]",
    "linuxConfiguration": {
      "disablePasswordAuthentication": true,
      "ssh": {
        "publicKeys": [
          {
            "path": "[concat('/home/', parameters('adminUsername'), '/.ssh/authorized_keys')]",
            "keyData": "[parameters('adminPasswordOrSSHKey')]"
          }
        ]
      }
    },
    "storageAccountName": "[toLower(uniqueString(resourceGroup().id) )]",
    "containerName": "[concat('hivemq-cluster-container-', uniqueString( resourceGroup().id, deployment().name ))]",
    "setupScriptLink": "https://raw.githubusercontent.com/floresboy/Azure-HiveMQ-Cluster-v26.2/refs/heads/main/scripts/hivemq_node_setup.sh"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2019-06-01",
      "name": "[variables('storageAccountName')]",
      "location": "[resourceGroup().location]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": { "accessTier": "Hot" },
      "resources": [
        {
          "type": "blobServices/containers",
          "apiVersion": "2019-06-01",
          "name": "[concat('default/', variables('containerName'))]",
          "dependsOn": [ "[variables('storageAccountName')]" ]
        }
      ]
    },
    {
      "condition": "[parameters('deployPublicIPs')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2020-05-01",
      "name": "[concat(variables('vmName'), copyIndex(),'-public-ip')]",
      "copy": { "name": "publicIpLoop", "count": "[parameters('numberOfInstances')]" },
      "location": "[resourceGroup().location]",
      "properties": { "publicIPAllocationMethod": "Dynamic" }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2020-05-01",
      "name": "[variables('loadBalancerPublicIpName')]",
      "location": "[resourceGroup().location]",
      "properties": { "publicIPAllocationMethod": "Dynamic" }
    },
    {
      "condition": "[parameters('deployBastion')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2020-05-01",
      "name": "[variables('bastionPublicIpName')]",
      "location": "[resourceGroup().location]",
      "sku": { "name": "Standard" },
      "properties": { "publicIPAllocationMethod": "Static" }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2019-11-01",
      "name": "[variables('virtualNetworkName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "addressSpace": { "addressPrefixes": [ "[variables('addressPrefix')]" ] },
        "subnets": "[union(array(json(concat('{\"name\":\"', variables('subnetName'), '\",\"properties\":{\"addressPrefix\":\"', variables('subnetPrefix'), '\"}}'))), if(parameters('deployBastion'), array(json(concat('{\"name\":\"', variables('bastionSubnetName'), '\",\"properties\":{\"addressPrefix\":\"', variables('bastionSubnetPrefix'), '\"}}'))), array()))]"
      }
    },
    {
      "condition": "[parameters('deployBastion')]",
      "type": "Microsoft.Network/bastionHosts",
      "apiVersion": "2020-05-01",
      "name": "[variables('bastionHostName')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[variables('virtualNetworkNetworkName')]",
        "[variables('bastionPublicIpName')]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "IpConf",
            "properties": {
              "subnet": { "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('bastionSubnetName'))]" },
              "publicIPAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('bastionPublicIpName'))]" }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2019-11-01",
      "name": "[concat(variables('nicName'), copyIndex())]",
      "location": "[resourceGroup().location]",
      "copy": { "name": "nicLoop", "count": "[parameters('numberOfInstances')]" },
      "dependsOn": [
        "[variables('virtualNetworkName')]",
        "[variables('loadBalancersName')]",
        "publicIpLoop"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "publicIPAddress": "[if(parameters('deployPublicIPs'), json(concat('{\"id\": \"', resourceId('Microsoft.Network/publicIPAddresses', concat(variables('vmName'), copyIndex(), '-public-ip')), '\"}')), json('null'))]",
              "privateIPAllocationMethod": "Dynamic",
              "subnet": { "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('subnetName'))]" },
              "loadBalancerBackendAddressPools": [
                { "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools', variables('loadBalancersName'), variables('backendPoolName'))]" }
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2019-12-01",
      "name": "[concat(variables('vmName'), copyIndex())]",
      "location": "[resourceGroup().location]",
      "copy": { "name": "virtualMachineLoop", "count": "[parameters('numberOfInstances')]" },
      "dependsOn": [ "nicLoop", "[variables('storageAccountName')]", "[variables('asName')]" ],
      "properties": {
        "availabilitySet": { "id": "[resourceId('Microsoft.Compute/availabilitySets',variables('asName'))]" },
        "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
        "networkProfile": {
          "networkInterfaces": [ { "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('nicName'), copyIndex()))]" } ]
        },
        "osProfile": {
          "computerName": "[concat(variables('vmName'), copyIndex())]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPasswordOrSSHKey')]",
          "linuxConfiguration": "[if(equals(parameters('authenticationType'), 'password'), json('null'), variables('linuxConfiguration'))]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "[variables('imagePublisher')]",
            "offer": "[variables('imageOffer')]",
            "sku": "[variables('ubuntuOSVersion')]",
            "version": "latest"
          },
          "osDisk": { "createOption": "FromImage", "managedDisk": { "storageAccountType": "StandardSSD_LRS" } },
          "dataDisks": [ { "diskSizeGB": 1023, "lun": 0, "createOption": "Empty" } ]
        }
      },
      "resources": [
        {
          "type": "extensions",
          "apiVersion": "2019-12-01",
          "name": "[concat('hivemq-node-setup-extension-', copyIndex())]",
          "location": "[resourceGroup().location]",
          "dependsOn": [ "[resourceId('Microsoft.Compute/virtualMachines', concat(variables('vmName'), copyIndex()))]" ],
          "properties": {
            "publisher": "Microsoft.Azure.Extensions",
            "type": "CustomScript",
            "typeHandlerVersion": "2.0",
            "autoUpgradeMinorVersion": true,
            "settings": { "fileUris": [ "[variables('setupScriptLink')]" ] },
            "protectedSettings": {
              "commandToExecute": "[format('sh hivemq_node_setup.sh {0} {1} {2} {3}', parameters('hivemqVersion'), concat('\"' ,'DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), providers('Microsoft.Storage', 'storageAccounts').apiVersions[0]).keys[0].value,';EndpointSuffix=core.windows.net', '\"'), variables('containerName'), parameters('azureDiscoveryExtensionVersion'))]"
            }
          }
        }
      ]
    },
    {
      "type": "Microsoft.Network/loadBalancers",
      "apiVersion": "2019-11-01",
      "name": "[variables('loadBalancersName')]",
      "location": "[resourceGroup().location]",
      "sku": { "name": "Basic" },
      "dependsOn": [ "[variables('loadBalancerPublicIpName')]", "[variables('virtualNetworkName')]" ],
      "properties": {
        "frontendIPConfigurations": [
          {
            "name": "[variables('frontendName')]",
            "properties": { "publicIPAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('loadBalancerPublicIpName'))]" } }
          }
        ],
        "backendAddressPools": [ { "name": "[variables('backendPoolName')]" } ],
        "loadBalancingRules": [
          {
            "name": "[concat(variables('loadBalancersName'), '-CC')]",
            "properties": {
              "frontendIPConfiguration": { "id": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations', variables('loadBalancersName'), variables('frontendName'))]" },
              "frontendPort": 8080, "backendPort": 8080, "protocol": "Tcp",
              "backendAddressPool": { "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools', variables('loadBalancersName'), variables('backendPoolName'))]" },
              "probe": { "id": "[resourceId('Microsoft.Network/loadBalancers/probes', variables('loadBalancersName'), variables('healthProbeControlCenter'))]" }
            }
          },
          {
            "name": "[concat(variables('loadBalancersName'), '-MQTT')]",
            "properties": {
              "frontendIPConfiguration": { "id": "[resourceId('Microsoft.Network/loadBalancers/frontendIPConfigurations', variables('loadBalancersName'), variables('frontendName'))]" },
              "frontendPort": 1883, "backendPort": 1883, "protocol": "Tcp",
              "backendAddressPool": { "id": "[resourceId('Microsoft.Network/loadBalancers/backendAddressPools', variables('loadBalancersName'), variables('backendPoolName'))]" },
              "probe": { "id": "[resourceId('Microsoft.Network/loadBalancers/probes', variables('loadBalancersName'), variables('healthProbeHivemq'))]" }
            }
          }
        ],
        "probes": [
          { "name": "[variables('healthProbeHivemq')]", "properties": { "protocol": "Tcp", "port": 1883, "intervalInSeconds": 5, "numberOfProbes": 2 } },
          { "name": "[variables('healthProbeControlCenter')]", "properties": { "protocol": "Tcp", "port": 8080, "intervalInSeconds": 5, "numberOfProbes": 2 } }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/availabilitySets",
      "apiVersion": "2019-03-01",
      "name": "[variables('asName')]",
      "location": "[resourceGroup().location]",
      "sku": { "name": "Aligned" },
      "properties": { "platformUpdateDomainCount": 2, "platformFaultDomainCount": 2 }
    }
  ]
}
